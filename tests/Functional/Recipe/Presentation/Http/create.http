POST http://localhost:8000/api/v1/recipes/create
Content-Type: application/json

{
    "name": "A recipe with empty steps",
    "description": "Some description with empty steps",
    "source": "Some source with empty steps",
    "rating": 2,
    "servings": 2,
    "steps": [],
    "ingredients": []
}

###

POST http://localhost:8000/api/v1/recipes/create
Content-Type: application/json

{
    "name": "Another recipe with some steps",
    "description": "Some description with some steps",
    "source": "Some source with some steps",
    "rating": 2,
    "servings": 2,
    "steps": [
        {
            "description": "XXThis is the first step in the recipe.",
            "ordering": 1
        },
        {
            "description": "YYYThis is the second step in the recipe.",
            "ordering": 2
        }
    ],
    "ingredients": [
        {
            "ingredientId": "fc066bb1-22a9-47a4-981d-81f5065b461f",
            "unitOfMeasureId": "647bfd95-ba44-47bd-a745-2a7b4e9c055b",
            "quantity": 1.0,
            "ordering": 1
        }
    ]
}

